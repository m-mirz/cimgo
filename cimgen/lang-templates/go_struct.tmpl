package cimgostructs

import "cimgo/cimgobase"

// {{.Comment}}
type {{.Id}} struct {
{{- if .SuperType}}
    {{.SuperType}}
{{- else}}
    cimgobase.Base
{{- end}}

{{- range .Attributes}}
{{- if .IsAssociationUsed }}
    // {{.Comment}}
{{- if or .IsPrimitive .IsCIMDatatype}}
    {{capitalFirstLetter .Label}} {{.LangType}} `xml:"{{.Id}},omitempty"`
{{- else if .IsEnumValue}}
    {{capitalFirstLetter .Label}} *struct {
        URI string `xml:"resource,attr"`
    } `xml:"{{.Id}},omitempty"`
{{- else}}
    {{capitalFirstLetter .Label}} *struct {
        MRID string `xml:"resource,attr"`
    } `xml:"{{.Id}},omitempty"`
{{- end}}
{{- end}}
{{- end}}
}

var info{{.Id}} = cimgobase.CIMTypeInfo{
    Id: "{{.Id}}",
    Label: "{{.Label}}",
    Namespace: "{{.Namespace}}",
    Origin: "{{.Origin}}",
    Origins: []string{ {{- range .Origins}}
        "{{.}}",{{- end}} 
    },
    Attributes: map[string]cimgobase.CIMAttributeInfo{
{{- range .Attributes}}
{{- if .IsAssociationUsed }}
        "{{.Id}}": {
            Label: "{{.Label}}",
            Namespace: "{{.Namespace}}",
            Origin: "{{.Origin}}",            
        },
{{- end}}
{{- end}}
    },
}
