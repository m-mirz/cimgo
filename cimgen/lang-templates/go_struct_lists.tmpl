package cimstructs

import (
	"cimgo/cimbase"
	"fmt"
	"reflect"
)

type CIMElementList struct {
	Elements map[string]interface{}
	{{- range .Types}}
	{{- if or (eq .CIMStereotype "concrete") (eq .CIMStereotype "Compound")}}
	{{.Id}}s map[string]*{{.Id}}
	{{- end}}
	{{- end}}
}

func NewCIMElementList() *CIMElementList {
	return &CIMElementList{
		Elements: make(map[string]interface{}),
		{{- range .Types}}
		{{- if or (eq .CIMStereotype "concrete") (eq .CIMStereotype "Compound")}}
		{{.Id}}s: make(map[string]*{{.Id}}),
		{{- end}}
		{{- end}}
	}
}

func (ds *CIMElementList) AddElement(element interface{}) error {
	elem, ok := element.(cimbase.CIMElement)
	if !ok {
		return fmt.Errorf("element of type %T does not implement CIMElement", element)
	}
	id := elem.GetId()

	if existing, ok := ds.Elements[id]; ok {
		err := cimbase.DeepMerge(reflect.ValueOf(existing), reflect.ValueOf(element))
		if err != nil {
			return fmt.Errorf("ID conflict: element with ID %s already exists and cannot be merged: %v", id, err)
		}
	} else {
		// Add new element
		ds.Elements[id] = element
		switch e := element.(type) {
		{{- range .Types}}
		{{- if or (eq .CIMStereotype "concrete") (eq .CIMStereotype "Compound")}}
		case *{{.Id}}:
			ds.{{.Id}}s[e.GetId()] = e
			{{- end}}
			{{- end}}
		default:
			return fmt.Errorf("unknown CIM type: %T", e)
		}
	}
	return nil
}

var StructMap = map[string]func() interface{}{
	{{- range .Types}}
	{{- if or (eq .CIMStereotype "concrete") (eq .CIMStereotype "Compound")}}
	"{{.Id}}": func() interface{} {
		return &{{.Id}}{}
	},
	{{- end}}
	{{- end}}
}

// TypeInfoMap maps CIM type name to its type info (all types, including abstract).
var TypeInfoMap = map[string]cimbase.CIMTypeInfo{
	{{- range .Types}}
	"{{.Id}}": {
		Namespace: "{{.Namespace}}",
		Origin:    "{{.Origin}}",
		Origins:   []string{ {{- range .Origins}}"{{.}}", {{- end}} },
	},
	{{- end}}
}

// AttributeInfoMap maps xml element name (e.g. "TapChanger.step") to its attribute info.
var AttributeInfoMap = map[string]cimbase.CIMAttributeInfo{
	{{- range .Types}}
	{{- range .Attributes}}
	{{- if .IsAssociationUsed}}
	"{{.Id}}": {
		Namespace: "{{.Namespace}}",
		Origin:    "{{.Origin}}",
		Origins:   []string{ {{- range .Origins}}"{{.}}", {{- end}} },
	},
	{{- end}}
	{{- end}}
	{{- end}}
}
