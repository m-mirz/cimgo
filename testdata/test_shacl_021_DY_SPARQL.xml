<?xml version="1.0" encoding="utf-8" ?>
<rdf:RDF xmlns:cim="http://iec.ch/TC57/CIM100#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <cim:SynchronousMachine rdf:ID="SM.1">
    <cim:RotatingMachine.ratedPowerFactor>0.8</cim:RotatingMachine.ratedPowerFactor>
    <cim:RotatingMachine.ratedS>100.0</cim:RotatingMachine.ratedS>
  </cim:SynchronousMachine>

  <cim:SynchronousMachineUserDefined rdf:ID="SMD.1">
    <cim:SynchronousMachineDynamics.SynchronousMachine rdf:resource="#SM.1" />
  </cim:SynchronousMachineUserDefined>

  <!-- OK: mwbase = 0.8 * 100 = 80 -->
  <cim:GovSteamSGO rdf:ID="GOV.OK">
    <cim:TurbineGovernorDynamics.SynchronousMachineDynamics rdf:resource="#SMD.1" />
    <cim:GovSteamSGO.mwbase>80.0</cim:GovSteamSGO.mwbase>
  </cim:GovSteamSGO>

  <!-- BAD: mwbase != 80 -->
  <cim:GovSteamSGO rdf:ID="GOV.BAD">
    <cim:TurbineGovernorDynamics.SynchronousMachineDynamics rdf:resource="#SMD.1" />
    <cim:GovSteamSGO.mwbase>90.0</cim:GovSteamSGO.mwbase>
  </cim:GovSteamSGO>
</rdf:RDF>
