<?xml version="1.0" encoding="utf-8" ?>
<rdf:RDF xmlns:cim="http://iec.ch/TC57/CIM100#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <cim:BaseVoltage rdf:ID="BV.110">
    <cim:BaseVoltage.nominalVoltage>110.0</cim:BaseVoltage.nominalVoltage>
  </cim:BaseVoltage>
  <cim:BaseVoltage rdf:ID="BV.220">
    <cim:BaseVoltage.nominalVoltage>220.0</cim:BaseVoltage.nominalVoltage>
  </cim:BaseVoltage>
  
  <cim:VoltageLevel rdf:ID="VL.110">
    <cim:VoltageLevel.BaseVoltage rdf:resource="#BV.110" />
  </cim:VoltageLevel>
  <cim:VoltageLevel rdf:ID="VL.220">
    <cim:VoltageLevel.BaseVoltage rdf:resource="#BV.220" />
  </cim:VoltageLevel>

  <cim:ConnectivityNode rdf:ID="CN.110.A">
    <cim:ConnectivityNode.ConnectivityNodeContainer rdf:resource="#VL.110" />
  </cim:ConnectivityNode>
  <cim:ConnectivityNode rdf:ID="CN.110.B">
    <cim:ConnectivityNode.ConnectivityNodeContainer rdf:resource="#VL.110" />
  </cim:ConnectivityNode>
  <cim:ConnectivityNode rdf:ID="CN.220.A">
    <cim:ConnectivityNode.ConnectivityNodeContainer rdf:resource="#VL.220" />
  </cim:ConnectivityNode>

  <!-- 1. Switch-connection OK: same VoltageLevel -->
  <cim:Breaker rdf:ID="SW.OK.SAME_VL">
    <cim:IdentifiedObject.name>SW OK SAME VL</cim:IdentifiedObject.name>
  </cim:Breaker>
  <cim:Terminal rdf:ID="Term.SW.OK.1">
    <cim:Terminal.ConductingEquipment rdf:resource="#SW.OK.SAME_VL" />
    <cim:ACDCTerminal.sequenceNumber>1</cim:ACDCTerminal.sequenceNumber>
    <cim:Terminal.ConnectivityNode rdf:resource="#CN.110.A" />
  </cim:Terminal>
  <cim:Terminal rdf:ID="Term.SW.OK.2">
    <cim:Terminal.ConductingEquipment rdf:resource="#SW.OK.SAME_VL" />
    <cim:ACDCTerminal.sequenceNumber>2</cim:ACDCTerminal.sequenceNumber>
    <cim:Terminal.ConnectivityNode rdf:resource="#CN.110.B" />
  </cim:Terminal>

  <!-- 2. Switch-connection BAD: different BaseVoltage -->
  <cim:Breaker rdf:ID="SW.BAD.DIFF_BV">
    <cim:IdentifiedObject.name>SW BAD DIFF BV</cim:IdentifiedObject.name>
  </cim:Breaker>
  <cim:Terminal rdf:ID="Term.SW.BAD.1">
    <cim:Terminal.ConductingEquipment rdf:resource="#SW.BAD.DIFF_BV" />
    <cim:ACDCTerminal.sequenceNumber>1</cim:ACDCTerminal.sequenceNumber>
    <cim:Terminal.ConnectivityNode rdf:resource="#CN.110.A" />
  </cim:Terminal>
  <cim:Terminal rdf:ID="Term.SW.BAD.2">
    <cim:Terminal.ConductingEquipment rdf:resource="#SW.BAD.DIFF_BV" />
    <cim:ACDCTerminal.sequenceNumber>2</cim:ACDCTerminal.sequenceNumber>
    <cim:Terminal.ConnectivityNode rdf:resource="#CN.220.A" />
  </cim:Terminal>

  <!-- 3. Terminal-connection BAD: same ConnectivityNode -->
  <cim:ACLineSegment rdf:ID="Line.BAD.SAME_CN">
    <cim:IdentifiedObject.name>Line BAD SAME CN</cim:IdentifiedObject.name>
  </cim:ACLineSegment>
  <cim:Terminal rdf:ID="Term.Line.BAD.1">
    <cim:Terminal.ConductingEquipment rdf:resource="#Line.BAD.SAME_CN" />
    <cim:ACDCTerminal.sequenceNumber>1</cim:ACDCTerminal.sequenceNumber>
    <cim:Terminal.ConnectivityNode rdf:resource="#CN.110.A" />
  </cim:Terminal>
  <cim:Terminal rdf:ID="Term.Line.BAD.2">
    <cim:Terminal.ConductingEquipment rdf:resource="#Line.BAD.SAME_CN" />
    <cim:ACDCTerminal.sequenceNumber>2</cim:ACDCTerminal.sequenceNumber>
    <cim:Terminal.ConnectivityNode rdf:resource="#CN.110.A" />
  </cim:Terminal>
</rdf:RDF>
