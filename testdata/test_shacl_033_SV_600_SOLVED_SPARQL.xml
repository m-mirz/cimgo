<?xml version="1.0" encoding="utf-8" ?>
<rdf:RDF xmlns:cim="http://iec.ch/TC57/CIM100#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <!-- Infrastructure -->
  <cim:TopologicalNode rdf:ID="TN.1" />
  <cim:TopologicalIsland rdf:ID="TI.1">
    <cim:TopologicalIsland.TopologicalNodes rdf:resource="#TN.1" />
  </cim:TopologicalIsland>

  <!-- 1. Dangling Reference -->
  <cim:Substation rdf:ID="S1">
    <cim:IdentifiedObject.name>S1</cim:IdentifiedObject.name>
    <cim:Substation.Region rdf:resource="#NON_EXISTENT_REGION" />
  </cim:Substation>

  <!-- 2. ShuntCompensator Sync -->
  <cim:LinearShuntCompensator rdf:ID="LSC.SYNC.BAD">
    <cim:RegulatingCondEq.controlEnabled>false</cim:RegulatingCondEq.controlEnabled>
    <cim:ShuntCompensator.sections>1.0</cim:ShuntCompensator.sections>
  </cim:LinearShuntCompensator>
  <cim:Terminal rdf:ID="Term.LSC.1">
    <cim:Terminal.ConductingEquipment rdf:resource="#LSC.SYNC.BAD" />
    <cim:Terminal.TopologicalNode rdf:resource="#TN.1" />
  </cim:Terminal>
  <cim:SvStatus rdf:ID="SVS.LSC.1">
    <cim:SvStatus.ConductingEquipment rdf:resource="#LSC.SYNC.BAD" />
    <cim:SvStatus.inService>true</cim:SvStatus.inService>
  </cim:SvStatus>
  <cim:SvShuntCompensatorSections rdf:ID="SVSC.SYNC.BAD">
    <cim:SvShuntCompensatorSections.ShuntCompensator rdf:resource="#LSC.SYNC.BAD" />
    <cim:SvShuntCompensatorSections.sections>2.0</cim:SvShuntCompensatorSections.sections> <!-- Mismatch: 2.0 != 1.0 -->
  </cim:SvShuntCompensatorSections>

  <!-- 3. TapChanger Sync -->
  <cim:RatioTapChanger rdf:ID="RTC.SYNC.BAD">
    <cim:TapChanger.controlEnabled>false</cim:TapChanger.controlEnabled>
    <cim:TapChanger.step>5.0</cim:TapChanger.step>
    <cim:RatioTapChanger.TransformerEnd rdf:resource="#PTE.1" />
  </cim:RatioTapChanger>
  <cim:PowerTransformerEnd rdf:ID="PTE.1">
    <cim:TransformerEnd.Terminal rdf:resource="#Term.PTE.1" />
  </cim:PowerTransformerEnd>
  <cim:Terminal rdf:ID="Term.PTE.1">
    <cim:Terminal.TopologicalNode rdf:resource="#TN.1" />
  </cim:Terminal>
  <cim:SvTapStep rdf:ID="SVTS.SYNC.BAD">
    <cim:SvTapStep.TapChanger rdf:resource="#RTC.SYNC.BAD" />
    <cim:SvTapStep.position>6.0</cim:SvTapStep.position> <!-- Mismatch: 6.0 != 5.0 -->
  </cim:SvTapStep>

  <!-- 4. Missing state variables for energized equipment -->
  <cim:SynchronousMachine rdf:ID="SM.ENERGIZED.NO_STATUS" />
  <cim:Terminal rdf:ID="Term.SM.2">
    <cim:Terminal.ConductingEquipment rdf:resource="#SM.ENERGIZED.NO_STATUS" />
    <cim:Terminal.TopologicalNode rdf:resource="#TN.1" />
  </cim:Terminal>
  <!-- No SvStatus for SM.ENERGIZED.NO_STATUS should fail -->

  <cim:LinearShuntCompensator rdf:ID="LSC.ENERGIZED.NO_SVSC" />
  <cim:Terminal rdf:ID="Term.LSC.2">
    <cim:Terminal.ConductingEquipment rdf:resource="#LSC.ENERGIZED.NO_SVSC" />
    <cim:Terminal.TopologicalNode rdf:resource="#TN.1" />
  </cim:Terminal>
  <cim:SvStatus rdf:ID="SVS.LSC.2">
    <cim:SvStatus.ConductingEquipment rdf:resource="#LSC.ENERGIZED.NO_SVSC" />
    <cim:SvStatus.inService>true</cim:SvStatus.inService>
  </cim:SvStatus>
  <!-- No SvShuntCompensatorSections for LSC.ENERGIZED.NO_SVSC should fail -->
</rdf:RDF>
