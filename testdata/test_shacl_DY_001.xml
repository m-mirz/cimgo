<?xml version="1.0" encoding="utf-8" ?>
<rdf:RDF xmlns:cim="http://iec.ch/TC57/CIM100#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <cim:AsynchronousMachine rdf:ID="AsynchronousMachine.REF">
    <cim:IdentifiedObject.mRID>AsynchronousMachine.REF</cim:IdentifiedObject.mRID>
    <cim:IdentifiedObject.name>AM1</cim:IdentifiedObject.name>
  </cim:AsynchronousMachine>
  <!-- tppo must be < tpo (sh:lessThan) -->
  <!-- satisfies: statorLeakageReactance < xpp <= xp <= xs -->
  <cim:AsynchronousMachineTimeConstantReactance rdf:ID="AsynchronousMachineTimeConstantReactance.OK">
    <cim:IdentifiedObject.mRID>AsynchronousMachineTimeConstantReactance.OK</cim:IdentifiedObject.mRID>
    <cim:IdentifiedObject.name>AMTCR-OK</cim:IdentifiedObject.name>
    <cim:AsynchronousMachineDynamics.AsynchronousMachine rdf:resource="#AsynchronousMachine.REF"/>
    <cim:RotatingMachineDynamics.damping>0.1</cim:RotatingMachineDynamics.damping>
    <cim:RotatingMachineDynamics.inertia>3.0</cim:RotatingMachineDynamics.inertia>
    <cim:RotatingMachineDynamics.statorLeakageReactance>0.1</cim:RotatingMachineDynamics.statorLeakageReactance>
    <cim:RotatingMachineDynamics.statorResistance>0.01</cim:RotatingMachineDynamics.statorResistance>
    <cim:AsynchronousMachineTimeConstantReactance.xs>3.0</cim:AsynchronousMachineTimeConstantReactance.xs>
    <cim:AsynchronousMachineTimeConstantReactance.xp>0.2</cim:AsynchronousMachineTimeConstantReactance.xp>
    <cim:AsynchronousMachineTimeConstantReactance.xpp>0.15</cim:AsynchronousMachineTimeConstantReactance.xpp>
    <cim:AsynchronousMachineTimeConstantReactance.tppo>0.01</cim:AsynchronousMachineTimeConstantReactance.tppo>
    <cim:AsynchronousMachineTimeConstantReactance.tpo>0.1</cim:AsynchronousMachineTimeConstantReactance.tpo>
  </cim:AsynchronousMachineTimeConstantReactance>
  <!-- tppo=0.1 >= tpo=0.05 violates sh:lessThan -->
  <cim:AsynchronousMachineTimeConstantReactance rdf:ID="AsynchronousMachineTimeConstantReactance.BAD">
    <cim:IdentifiedObject.mRID>AsynchronousMachineTimeConstantReactance.BAD</cim:IdentifiedObject.mRID>
    <cim:IdentifiedObject.name>AMTCR-BAD</cim:IdentifiedObject.name>
    <cim:AsynchronousMachineDynamics.AsynchronousMachine rdf:resource="#AsynchronousMachine.REF"/>
    <cim:RotatingMachineDynamics.damping>0.1</cim:RotatingMachineDynamics.damping>
    <cim:RotatingMachineDynamics.inertia>3.0</cim:RotatingMachineDynamics.inertia>
    <cim:RotatingMachineDynamics.statorLeakageReactance>0.1</cim:RotatingMachineDynamics.statorLeakageReactance>
    <cim:RotatingMachineDynamics.statorResistance>0.01</cim:RotatingMachineDynamics.statorResistance>
    <cim:AsynchronousMachineTimeConstantReactance.xs>3.0</cim:AsynchronousMachineTimeConstantReactance.xs>
    <cim:AsynchronousMachineTimeConstantReactance.xp>0.2</cim:AsynchronousMachineTimeConstantReactance.xp>
    <cim:AsynchronousMachineTimeConstantReactance.xpp>0.15</cim:AsynchronousMachineTimeConstantReactance.xpp>
    <cim:AsynchronousMachineTimeConstantReactance.tppo>0.1</cim:AsynchronousMachineTimeConstantReactance.tppo>
    <cim:AsynchronousMachineTimeConstantReactance.tpo>0.05</cim:AsynchronousMachineTimeConstantReactance.tpo>
  </cim:AsynchronousMachineTimeConstantReactance>
</rdf:RDF>
