<?xml version="1.0" encoding="utf-8" ?>
<rdf:RDF xmlns:cim="http://iec.ch/TC57/CIM100#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <!-- PowerTransformerEnd.phaseAngleClock must be in [0, 11] (sh:maxInclusive 11) -->
  <cim:PowerTransformerEnd rdf:ID="PowerTransformerEnd.OK">
    <cim:IdentifiedObject.name>PTE-OK</cim:IdentifiedObject.name>
    <cim:TransformerEnd.grounded>false</cim:TransformerEnd.grounded>
    <cim:PowerTransformerEnd.phaseAngleClock>5</cim:PowerTransformerEnd.phaseAngleClock>
    <cim:PowerTransformerEnd.r0>0.1</cim:PowerTransformerEnd.r0>
    <cim:PowerTransformerEnd.x0>0.1</cim:PowerTransformerEnd.x0>
    <cim:PowerTransformerEnd.g0>0.1</cim:PowerTransformerEnd.g0>
    <cim:PowerTransformerEnd.b0>0.1</cim:PowerTransformerEnd.b0>
  </cim:PowerTransformerEnd>
  <!-- phaseAngleClock=12 violates sh:maxInclusive 11 -->
  <cim:PowerTransformerEnd rdf:ID="PowerTransformerEnd.BAD">
    <cim:IdentifiedObject.name>PTE-BAD</cim:IdentifiedObject.name>
    <cim:TransformerEnd.grounded>false</cim:TransformerEnd.grounded>
    <cim:PowerTransformerEnd.phaseAngleClock>12</cim:PowerTransformerEnd.phaseAngleClock>
    <cim:PowerTransformerEnd.r0>0.1</cim:PowerTransformerEnd.r0>
    <cim:PowerTransformerEnd.x0>0.1</cim:PowerTransformerEnd.x0>
    <cim:PowerTransformerEnd.g0>0.1</cim:PowerTransformerEnd.g0>
    <cim:PowerTransformerEnd.b0>0.1</cim:PowerTransformerEnd.b0>
  </cim:PowerTransformerEnd>
</rdf:RDF>
