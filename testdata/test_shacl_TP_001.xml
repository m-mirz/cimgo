<?xml version="1.0" encoding="utf-8" ?>
<rdf:RDF xmlns:cim="http://iec.ch/TC57/CIM100#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <!-- Referenced by TopologicalNodes -->
  <cim:BaseVoltage rdf:ID="BaseVoltage.REF"/>
  <cim:VoltageLevel rdf:ID="VoltageLevel.REF"/>
  <!-- TopologicalNode.name is required (sh:required) -->
  <cim:TopologicalNode rdf:ID="TopologicalNode.OK">
    <cim:IdentifiedObject.mRID>TopologicalNode.OK</cim:IdentifiedObject.mRID>
    <cim:IdentifiedObject.name>TN-OK</cim:IdentifiedObject.name>
    <cim:TopologicalNode.BaseVoltage rdf:resource="#BaseVoltage.REF"/>
    <cim:TopologicalNode.ConnectivityNodeContainer rdf:resource="#VoltageLevel.REF"/>
  </cim:TopologicalNode>
  <!-- name absent: violates sh:required -->
  <cim:TopologicalNode rdf:ID="TopologicalNode.BAD">
    <cim:IdentifiedObject.mRID>TopologicalNode.BAD</cim:IdentifiedObject.mRID>
    <cim:TopologicalNode.BaseVoltage rdf:resource="#BaseVoltage.REF"/>
    <cim:TopologicalNode.ConnectivityNodeContainer rdf:resource="#VoltageLevel.REF"/>
  </cim:TopologicalNode>
  <!-- One Terminal per TopologicalNode satisfies inverse mincount -->
  <cim:Terminal rdf:ID="Terminal.OK">
    <cim:Terminal.TopologicalNode rdf:resource="#TopologicalNode.OK"/>
  </cim:Terminal>
  <cim:Terminal rdf:ID="Terminal.BAD">
    <cim:Terminal.TopologicalNode rdf:resource="#TopologicalNode.BAD"/>
  </cim:Terminal>
</rdf:RDF>
