<?xml version="1.0" encoding="utf-8" ?>
<rdf:RDF xmlns:cim="http://iec.ch/TC57/CIM100#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <!-- 1. EnergySource.activePower-consumer -->
  <cim:EnergySource rdf:ID="ES.CONSUMER">
    <cim:EnergySource.activePower>10.0</cim:EnergySource.activePower>
  </cim:EnergySource>

  <!-- 2. RegulatingControl.targetDeadband-applicability -->
  <cim:RegulatingControl rdf:ID="RC.CONT.WITH.DEAD">
    <cim:RegulatingControl.discrete>false</cim:RegulatingControl.discrete>
    <cim:RegulatingControl.targetDeadband>1.0</cim:RegulatingControl.targetDeadband>
  </cim:RegulatingControl>
  <cim:RegulatingControl rdf:ID="RC.DISC.WITHOUT.DEAD">
    <cim:RegulatingControl.discrete>true</cim:RegulatingControl.discrete>
    <!-- targetDeadband missing -->
  </cim:RegulatingControl>

  <!-- 3. CsConverter range typical -->
  <cim:CsConverter rdf:ID="CSC.RECT.BAD.RANGE">
    <cim:CsConverter.operatingMode rdf:resource="http://iec.ch/TC57/CIM100#CsOperatingModeKind.rectifier" />
    <cim:CsConverter.maxAlpha>20.0</cim:CsConverter.maxAlpha>
    <cim:CsConverter.minAlpha>5.0</cim:CsConverter.minAlpha>
  </cim:CsConverter>

  <!-- 4. VsConverter P control -->
  <cim:VsConverter rdf:ID="VSC.P.BAD.DROOP">
    <cim:VsConverter.pPccControl rdf:resource="http://iec.ch/TC57/CIM100#VsPpccControlKind.pPccAndUdcDroop" />
    <cim:ACDCConverter.targetPpcc>100</cim:ACDCConverter.targetPpcc>
    <!-- Missing targetUdc and droop -->
  </cim:VsConverter>
</rdf:RDF>
