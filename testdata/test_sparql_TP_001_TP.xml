<?xml version="1.0" encoding="utf-8" ?>
<rdf:RDF xmlns:cim="http://iec.ch/TC57/CIM100#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <!-- OK: two terminals at same TN with identical phase codes -->
  <cim:TopologicalNode rdf:ID="TN.OK">
    <cim:IdentifiedObject.name>TN OK</cim:IdentifiedObject.name>
  </cim:TopologicalNode>
  <cim:Terminal rdf:about="#Term.OK.1">
    <cim:Terminal.TopologicalNode rdf:resource="#TN.OK" />
  </cim:Terminal>
  <cim:Terminal rdf:about="#Term.OK.2">
    <cim:Terminal.TopologicalNode rdf:resource="#TN.OK" />
  </cim:Terminal>

  <!-- BAD: two terminals at same TN with conflicting phase codes -->
  <cim:TopologicalNode rdf:ID="TN.BAD">
    <cim:IdentifiedObject.name>TN BAD</cim:IdentifiedObject.name>
  </cim:TopologicalNode>
  <cim:Terminal rdf:about="#Term.BAD.1">
    <cim:Terminal.TopologicalNode rdf:resource="#TN.BAD" />
  </cim:Terminal>
  <cim:Terminal rdf:about="#Term.BAD.2">
    <cim:Terminal.TopologicalNode rdf:resource="#TN.BAD" />
  </cim:Terminal>
</rdf:RDF>
