<?xml version="1.0" encoding="utf-8" ?>
<rdf:RDF xmlns:cim="http://iec.ch/TC57/CIM100#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <!-- OK: retained Switch -->
  <cim:Breaker rdf:ID="SW.OK">
    <cim:Switch.retained>true</cim:Switch.retained>
  </cim:Breaker>
  <cim:Terminal rdf:ID="Term.OK.1">
    <cim:Terminal.ConductingEquipment rdf:resource="#SW.OK" />
    <cim:ACDCTerminal.sequenceNumber>1</cim:ACDCTerminal.sequenceNumber>
  </cim:Terminal>
  <cim:Terminal rdf:ID="Term.OK.2">
    <cim:Terminal.ConductingEquipment rdf:resource="#SW.OK" />
    <cim:ACDCTerminal.sequenceNumber>2</cim:ACDCTerminal.sequenceNumber>
  </cim:Terminal>

  <!-- BAD: retained Switch whose two terminals land on the same TopologicalNode -->
  <cim:Breaker rdf:ID="SW.BAD">
    <cim:Switch.retained>true</cim:Switch.retained>
  </cim:Breaker>
  <cim:Terminal rdf:ID="Term.BAD.1">
    <cim:Terminal.ConductingEquipment rdf:resource="#SW.BAD" />
    <cim:ACDCTerminal.sequenceNumber>1</cim:ACDCTerminal.sequenceNumber>
  </cim:Terminal>
  <cim:Terminal rdf:ID="Term.BAD.2">
    <cim:Terminal.ConductingEquipment rdf:resource="#SW.BAD" />
    <cim:ACDCTerminal.sequenceNumber>2</cim:ACDCTerminal.sequenceNumber>
  </cim:Terminal>

  <!-- OK: not-retained Switch — rule does not apply -->
  <cim:Breaker rdf:ID="SW.NOT_RETAINED.OK">
    <cim:Switch.retained>false</cim:Switch.retained>
  </cim:Breaker>
  <cim:Terminal rdf:ID="Term.NR.1">
    <cim:Terminal.ConductingEquipment rdf:resource="#SW.NOT_RETAINED.OK" />
    <cim:ACDCTerminal.sequenceNumber>1</cim:ACDCTerminal.sequenceNumber>
  </cim:Terminal>
  <cim:Terminal rdf:ID="Term.NR.2">
    <cim:Terminal.ConductingEquipment rdf:resource="#SW.NOT_RETAINED.OK" />
    <cim:ACDCTerminal.sequenceNumber>2</cim:ACDCTerminal.sequenceNumber>
  </cim:Terminal>
</rdf:RDF>
